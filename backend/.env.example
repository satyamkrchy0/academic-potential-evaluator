# Server Configuration
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long_change_this
JWT_EXPIRES_IN=7d

# MongoDB Connection
# Get this from MongoDB Atlas: Database → Connect → Connect your application
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/employment_evaluator?retryWrites=true&w=majority

# PostgreSQL Connection
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Local: postgresql://postgres:password@localhost:5432/employment_evaluator
# Railway: Get from Railway dashboard
DATABASE_URL=postgresql://username:password@localhost:5432/employment_evaluator

# Python ML API URL
# Local development:
ML_API_URL=http://localhost:5001
# Production (after deploying to Railway):
# ML_API_URL=https://your-ml-api.railway.app

# OpenAI API Key (Optional - for AI career advice)
# Get from: https://platform.openai.com/api-keys
# Leave blank if you don't have one - app will work without it
OPENAI_API_KEY=
