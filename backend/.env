# Server Configuration
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long_change_this
JWT_EXPIRES_IN=7d

# MongoDB Connection
# Local mongodb connection string
MONGODB_URI=mongodb://127.0.0.1:27017/employment_evaluator

# PostgreSQL Connection
# Local: postgresql://postgres:password@localhost:5432/employment_evaluator
DATABASE_URL=postgresql://postgres:password@localhost:5432/employment_evaluator

# Python ML API URL
# Local development:
ML_API_URL=http://127.0.0.1:5001

# OpenAI API Key (Optional - for AI career advice)
OPENAI_API_KEY=
