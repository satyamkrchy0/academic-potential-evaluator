generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PredictionLog {
  id              Int      @id @default(autoincrement())
  userId          String
  employmentProb  Float
  readinessScore  Float
  predictionLabel String
  confidence      String
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
